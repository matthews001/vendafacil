{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(index|loja).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/funcionario/login",
      "destination": "/funcionario/login/index.html"
    },
    {
      "source": "/funcionario/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/entregador",
      "destination": "/entregador/index.html"
    },
    {
      "source": "/entregador/:path*",
      "destination": "/entregador/index.html"
    }
  ]
}
